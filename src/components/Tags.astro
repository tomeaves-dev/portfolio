---
const { tags } = Astro.props;

const isArray = Array.isArray(tags);
---

{isArray ? (
  <div class="tags">
    {tags.map(tag => (
      <span class="tag tag-tech">{tag}</span>
    ))}
  </div>
) : (
  <div class="tags">
    {tags.action?.map(action => (
      <a href={action.url} target="_blank" rel="noopener" class="tag tag-action">
        {action.label}
      </a>
    ))}

    {tags.status && (
      <span class={`tag tag-status tag-status--${tags.status.toLowerCase().replace(/\s+/g, '-')}`}>
        {tags.status}
      </span>
    )}

    {tags.tech?.map(tech => (
      <span class="tag tag-tech">{tech}</span>
    ))}
  </div>
)}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: 2px;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* Action — filled cyan */
  .tag-action {
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .tag-action:hover {
    opacity: 0.85;
  }

  /* Status — colour coded */
  .tag-status {
    border: 1px solid;
  }

  .tag-status--released {
    background: rgba(40, 200, 80, 0.12);
    color: #28c840;
    border-color: rgba(40, 200, 80, 0.3);
  }

  .tag-status--in-development {
    background: rgba(254, 188, 46, 0.12);
    color: #febc2e;
    border-color: rgba(254, 188, 46, 0.3);
  }

  .tag-status--on-hold {
    background: rgba(136, 136, 136, 0.12);
    color: var(--text-secondary);
    border-color: rgba(136, 136, 136, 0.3);
  }

  /* Tech / generic — subtle cyan outline */
  .tag-tech {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--border-glow);
  }
</style>