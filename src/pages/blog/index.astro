---
import Base from '../../layouts/Base.astro';
import Tags from '../../components/Tags.astro';
import { allPosts } from '../../data/blog.js';

const posts = allPosts();
---

<Base title="Blog">

  <div class="container page-header">
    <a href="/" class="back-link">← back to home</a>
    <p class="section-label">blog</p>
    <h1>All Posts</h1>
    <p class="page-sub">Devlogs, tutorials, and thoughts on indie game development.</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="posts-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-card-left">
              <Tags tags={post.tags} />
              <h2>{post.title}</h2>
              <p>{post.excerpt}</p>
            </div>
            <div class="post-card-right">
              <span class="post-date">
                {new Date(post.date).toLocaleDateString('en-GB', {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric',
                })}
              </span>
              <span class="post-reading-time">{post.readingTime} min read</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-4);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  .page-header h1 {
    margin: var(--space-4) 0 var(--space-3);
  }

  .page-sub {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: none;
  }

  /* POST LIST */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: start;
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-md);
  }

  .post-card:first-child {
    border-top: 1px solid var(--border);
  }

  .post-card:hover {
    opacity: 1;
  }

  .post-card:hover h2 {
    color: var(--accent);
  }

  .post-card-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-card-left h2 {
    font-size: var(--text-xl);
    transition: color var(--transition);
  }

  .post-card-left p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0;
  }

  .post-card-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    padding-top: var(--space-1);
    white-space: nowrap;
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .post-reading-time {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .post-card {
      grid-template-columns: 1fr;
    }

    .post-card-right {
      align-items: flex-start;
      flex-direction: row;
      gap: var(--space-4);
    }
  }
</style>