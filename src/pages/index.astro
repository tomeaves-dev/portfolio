---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import Tags from '../components/Tags.astro';
import { allProjects } from '../data/projects.js';

const projects = allProjects().filter(p => p.slug !== 'portfolio');
---

<Base title="Home">

  <!-- HERO -->
  <section class="hero">
    <video class="hero-video" autoplay loop muted playsinline>
      <source src="/videos/showreel.webm" type="video/webm" />
      <source src="/videos/showreel.mp4" type="video/mp4" />
    </video>
    <div class="hero-video-overlay"></div>
    <div class="container hero-inner">
      <p class="hero-available">
        <span class="available-dot"></span>
        Open To New Opportunities
      </p>
      <h1 class="hero-name">Tom Eaves</h1>
      <p class="hero-bio">
        Gameplay Programmer at <strong>Lucid Games</strong> with 3+ years of industry experience including work on <strong>Sea of Thieves</strong>.
        Specialising in network programming and physics-driven gameplay. Building indie projects in my spare time.
      </p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Get in Touch</a>
        <a href="/files/ThomasEaves_CV_260426.pdf" download class="btn btn-outline">Download CV</a>
      </div>
    </div>
  </section>

<!-- ABOUT -->
  <section class="section" id="about">
    <div class="container about-inner">
      <div class="about-text">
        <p class="section-label">about</p>
        <h2>About Me</h2>
        <p>
          Hi! I'm Tom.
        </p>
        <p>
          I'm a Gameplay Programmer based in the UK, currently at <strong>Lucid Games</strong> where
          I've worked on <strong>Sea of Thieves</strong> and several other multiplayer projects. I got into
          game dev at a young age, having released my first game on the <strong>iOS App Store at 13</strong>.
          Over a decade later, that passion has stayed with me.
        </p>
        <p>
          Outside of work I build personal projects to compliment my professional development. I'm most confident
          with <strong>UE5 and C++</strong> but I have experience with Godot, Unity, Bevy, C#, Rust and more.
        </p>
        <p>
          When I don't have a keyboard and mouse in front of me, I enjoy going to the gym, reading, travelling
          and - when weather and time allow - skiing! Oh, I also like pizza (evidently).
        </p>
        <a href="https://tommy-eaves-games.itch.io/" target="_blank" rel="noopener" class="btn btn-primary">Play My Games</a>
      </div>
      <div class="about-right">
        <img src="/images/tom.png" alt="Tom Eaves" class="about-photo" />
        <div class="terminal">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">terminal</span>
          </div>
          <pre class="terminal-body"><span class="t-prompt">$</span> whoami
<span class="t-out">> tomeaves-dev</span>

<span class="t-prompt">$</span> cat skills.txt
<span class="t-out">> C++ · C# · GDScript · Rust
> UE5 · Unity · Godot · Bevy
> network programming · physics systems</span>

<span class="t-prompt">$</span> echo $STATUS
<span class="t-out">> open to new opportunities</span></pre>
        </div>
      </div>
    </div>
  </section>

<!-- EXPERIENCE -->
  <section class="section" id="experience">
    <div class="container">
      <p class="section-label">experience</p>
      <h2>Where I've Worked</h2>

      <div class="timeline">

        <div class="timeline-item">
          <div class="timeline-date">2025 — Present</div>
          <div class="timeline-content">
            <h3>Lucid Games</h3>
            <p class="timeline-role">Mid-Level Gameplay Programmer</p>
            <p>
              Building multiplayer and physics-driven systems for <strong>Sea of Thieves</strong>,
              and other multiplayer projects, owning features end-to-end and collaborating closely with design.
            </p>
            <div class="timeline-tags">
              <span class="tag">UE5</span>
              <span class="tag">C++</span>
              <span class="tag">Network Programming</span>
              <span class="tag">Physics Systems</span>
              <span class="tag">Procedural Generation</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-date">2024 — 2025</div>
          <div class="timeline-content">
            <h3>Lucid Games</h3>
            <p class="timeline-role">Junior Gameplay Programmer</p>
            <p>
              Joined full-time after graduating. Worked on multiplayer gameplay systems,
              taking on increasing ownership and supporting teammates across disciplines.
            </p>
            <div class="timeline-tags">
              <span class="tag">UE5</span>
              <span class="tag">C++</span>
              <span class="tag">C#</span>
              <span class="tag">Multiplayer</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-date">2022 — 2023</div>
          <div class="timeline-content">
            <h3>Lucid Games</h3>
            <p class="timeline-role">Intern Gameplay Programmer</p>
            <p>
              12-month placement contributing to gameplay systems on a live commercial multiplayer title.
            </p>
            <div class="timeline-tags">
              <span class="tag">UE5</span>
              <span class="tag">C++</span>
              <span class="tag">Multiplayer</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section" id="projects">
    <div class="container">
      <p class="section-label">projects</p>
      <h2>Projects</h2>
      <p class="section-sub">A collection of some of my favourite personal projects. Take a look!</p>

      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-card">
            {project.thumbnail
              ? <img src={project.thumbnail} alt={`${project.title} screenshot`} class="project-thumb" />
              : <div class="project-thumb-placeholder"></div>
            }
            <div class="project-card-body">
              <Tags tags={project.tags} />
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-links">
                <a href={`/projects/${project.slug}`} class="btn btn-outline">Details →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <div class="container contact-inner">
      <p class="section-label">contact</p>
      <h2>Let's Talk</h2>
      <p>Have a project in mind, want to discuss a role, or just want to say hello?</p>
      <div class="contact-links">
  <div class="contact-row">
    <a href="mailto:hello@tomeaves.dev" class="btn btn-primary contact-btn">
      <Icon name="mdi:email" />
      hello@tomeaves.dev
    </a>
    <a href="/files/ThomasEaves_CV_260426.pdf" download class="btn btn-outline contact-btn">
      <Icon name="mdi:file-download" />
      Download CV
    </a>
  </div>
  <div class="contact-row">
    <a href="https://www.linkedin.com/in/thomasrichardeaves/" target="_blank" rel="noopener" class="contact-social">
      <Icon name="mdi:linkedin" />
      LinkedIn
    </a>
    <a href="https://github.com/tomeaves-dev" target="_blank" rel="noopener" class="contact-social">
      <Icon name="mdi:github" />
      GitHub
    </a>
    <a href="https://x.com/tomeaves_dev" target="_blank" rel="noopener" class="contact-social">
      <Icon name="mdi:twitter" />
      X / Twitter
    </a>
    <a href="https://tommy-eaves-games.itch.io/" target="_blank" rel="noopener" class="contact-social">
      <Icon name="mdi:gamepad-variant" />
      Itch.io
    </a>
  </div>
</div>
    </div>
  </section>

</Base>

<style>
  /* ── HERO ─────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-top: var(--nav-height);
  }

  .hero-bio strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .hero-available {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--border-glow);
    padding: var(--space-1) var(--space-3);
    border-radius: 2px;
    margin-bottom: var(--space-6);
    max-width: fit-content;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .available-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .hero-name {
    font-size: clamp(2.5rem, 7vw, var(--text-5xl));
    margin-bottom: var(--space-2);
    letter-spacing: -0.03em;
  }

  .hero-bio {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 55ch;
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    z-index: 0;
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.4) 0%,
      rgba(13, 13, 13, 0.7) 60%,
      rgba(13, 13, 13, 1) 100%
    );
    z-index: 1;
  }

  /* ── ABOUT ────────────────────────────────────────── */
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .about-text h2 {
    margin: var(--space-4) 0 var(--space-6);
  }

  .about-text p {
    margin-bottom: var(--space-4);
  }

  .about-text strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center center;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .terminal {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--accent-glow);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot.red    { background: #ff5f57; }
  .terminal-dot.yellow { background: #febc2e; }
  .terminal-dot.green  { background: #28c840; }

  .terminal-title {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0.05em;
  }

  .terminal-body {
    padding: var(--space-6);
    background: var(--bg-surface);
    border: none;
    border-left: none;
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .t-prompt { color: var(--accent); }
  .t-out    { color: var(--text-secondary); }

  /* ── PROJECTS ─────────────────────────────────────── */
  .section-sub {
    color: var(--text-secondary);
    margin: var(--space-2) 0 var(--space-12);
    max-width: none;
  }

  .section-sub a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .section-sub a:hover {
    opacity: 0.7;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .project-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color var(--transition-md), box-shadow var(--transition-md);
  }

  .project-card:hover {
    border-color: var(--border-glow);
    box-shadow: var(--accent-glow);
  }

  .project-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .project-thumb-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg-elevated);
    background-image: linear-gradient(
      135deg,
      var(--bg-elevated) 25%,
      var(--bg-surface) 100%
    );
  }

  .project-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project-card-body h3 {
    margin: 0;
  }

  .project-card-body p {
    font-size: var(--text-sm);
    margin: 0;
    flex: 1;
  }

  .project-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }

  /* ── EXPERIENCE ───────────────────────────────────── */
  .timeline {
    margin-top: var(--space-12);
    border-left: 1px solid var(--border);
    padding-left: var(--space-8);
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-12);
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-8) - 1px);
    top: 6px;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 8px var(--accent);
  }

  .timeline-date {
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .timeline-content h3 {
    margin-bottom: var(--space-1);
  }

  .timeline-role {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .timeline-content > p:last-of-type {
    margin-bottom: var(--space-4);
  }

  .timeline-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

/* ── CONTACT ──────────────────────────────────────── */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .contact-btn [data-icon] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .contact-social:hover {
    color: var(--accent);
    opacity: 1;
  }

  .contact-inner > p {
    margin-bottom: var(--space-8);
  }

  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .contact-social [data-icon] {
    width: 18px;
    height: 18px;
  }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>