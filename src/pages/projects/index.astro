---
import Base from '../../layouts/Base.astro';
import Tags from '../../components/Tags.astro';
import { allProjects } from '../../data/projects.js';

const projects = allProjects();
---

<Base title="Projects">

  <div class="container page-header">
    <a href="/" class="back-link">← back to home</a>
    <p class="section-label">projects</p>
    <h1>All Projects</h1>
    <p class="page-sub">Everything I've built, most recent first.</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-card">
            <div class="project-thumb-placeholder"></div>
            <div class="project-card-body">
              <Tags tags={project.tags} />
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-links">
                <a href={`/projects/${project.slug}`} class="btn btn-outline">Details →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-4);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  .page-header h1 {
    margin: var(--space-4) 0 var(--space-3);
  }

  .page-sub {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: none;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .project-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color var(--transition-md), box-shadow var(--transition-md);
  }

  .project-card:hover {
    border-color: var(--border-glow);
    box-shadow: var(--accent-glow);
  }

  .project-thumb-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg-elevated);
    background-image: linear-gradient(135deg, var(--bg-elevated) 25%, var(--bg-surface) 100%);
  }

  .project-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project-card-body h3 {
    margin: 0;
  }

  .project-card-body p {
    font-size: var(--text-sm);
    margin: 0;
    flex: 1;
  }

  .project-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }
</style>