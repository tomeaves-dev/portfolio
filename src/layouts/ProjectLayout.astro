---
import Base from './Base.astro';
import Tags from '../components/Tags.astro';

const { title, description, tags = { action: [], status: '', tech: [] }, screenshots = [] } = Astro.props;
---

<Base title={title}>
  <article class="project-page">

    <!-- BACK -->
    <div class="container back-row">
      <a href="/projects" class="back-link">← back to projects</a>
    </div>

    <!-- HERO -->
    <header class="project-hero">
      <div class="container">
        <Tags tags={tags} />
        <h1>{title}</h1>
        <p class="project-description">{description}</p>
      </div>
    </header>

    <!-- SCREENSHOTS -->
    <section class="section screenshots-section">
      <div class="container">
        <p class="section-label">screenshots</p>
        <div class:list={['screenshots-grid', { 'grid-2': screenshots.length > 0 && screenshots.length <= 4 }]}>
          {screenshots.length > 0 ? screenshots.map((src, i) => (
            <img src={src} alt={`${title} screenshot ${i + 1}`} class="screenshot" />
          )) : (
            <Fragment>
              <div class="screenshot-placeholder large"></div>
              <div class="screenshot-placeholder"></div>
              <div class="screenshot-placeholder"></div>
            </Fragment>
          )}
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section">
      <div class="container project-body">
        <div class="project-details">
          <p class="section-label">about</p>
          <slot />
        </div>
        <aside class="project-sidebar">
          <div class="sidebar-block">
            <p class="sidebar-label">Status</p>
            <p class="sidebar-value">{tags.status}</p>
          </div>
          {tags.tech?.length > 0 && (
            <div class="sidebar-block">
              <p class="sidebar-label">Tech</p>
              <div class="sidebar-tags">
                {tags.tech.map(t => <span class="tag tag-tech">{t}</span>)}
              </div>
            </div>
          )}
          {tags.action?.length > 0 && (
            <div class="sidebar-block">
              {tags.action.map(action => (
                <a href={action.url} target="_blank" rel="noopener" class="btn btn-primary" style="width: 100%; justify-content: center; margin-bottom: var(--space-2);">
                  {action.label}
                </a>
              ))}
            </div>
          )}
        </aside>
      </div>
    </section>

    <!-- TECH BREAKDOWN -->
    <section class="section tech-section">
      <div class="container">
        <p class="section-label">tech breakdown</p>
        <slot name="tech" />
      </div>
    </section>

    <!-- WHAT I LEARNED -->
    <section class="section learned-section">
      <div class="container">
        <p class="section-label">what i learned</p>
        <slot name="learned" />
      </div>
    </section>

  </article>
</Base>

<style>
  .back-row {
    padding-top: calc(var(--nav-height) + var(--space-8));
    padding-bottom: var(--space-4);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  .project-hero {
    padding: var(--space-8) 0 var(--space-16);
    border-bottom: 1px solid var(--border);
  }

  .project-hero h1 {
    margin: var(--space-6) 0 var(--space-6);
  }

  .project-description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 60ch;
    line-height: 1.6;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .screenshots-grid.grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .screenshot {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: var(--bg-elevated);
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .screenshot-placeholder {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    aspect-ratio: 16 / 9;
  }

  .screenshot-placeholder.large {
    grid-row: 1;
    aspect-ratio: unset;
  }

  .project-body {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-16);
    align-items: start;
  }

  .project-details :global(h2) {
    font-size: var(--text-2xl);
    margin: var(--space-8) 0 var(--space-4);
  }

  .project-details :global(h3) {
    font-size: var(--text-xl);
    margin: var(--space-6) 0 var(--space-3);
    color: var(--text-primary);
  }

  .project-details :global(p) {
    margin-bottom: var(--space-4);
    color: var(--text-secondary);
  }

  .project-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-8));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-6);
  }

  .sidebar-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sidebar-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    max-width: none;
  }

  .sidebar-value {
    font-size: var(--text-sm);
    color: var(--text-primary);
    max-width: none;
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-tech {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--border-glow);
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: 2px;
  }

  .tech-section,
  .learned-section {
    border-top: 1px solid var(--border);
  }

  .tech-section :global(p),
  .learned-section :global(p) {
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  @media (max-width: 768px) {
    .screenshots-grid,
    .screenshots-grid.grid-2 {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .screenshot-placeholder.large {
      aspect-ratio: 16 / 9;
    }

    .project-body {
      grid-template-columns: 1fr;
    }

    .project-sidebar {
      position: static;
    }
  }
</style>