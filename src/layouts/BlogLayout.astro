---
import Base from './Base.astro';
import Tags from '../components/Tags.astro';

const { title, date, excerpt, tags = [], readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base title={title}>
  <article class="blog-post">

    <!-- BACK -->
    <div class="container back-row">
      <a href="/blog" class="back-link">← back to blog</a>
    </div>

    <!-- HERO -->
    <header class="post-hero">
      <div class="container">
        <Tags tags={tags} />
        <h1>{title}</h1>
        <p class="post-excerpt">{excerpt}</p>
        <div class="post-meta">
          <span class="post-date">{formattedDate}</span>
          <span class="post-meta-divider">·</span>
          <span class="post-reading-time">{readingTime} min read</span>
        </div>
      </div>
    </header>

    <!-- BODY -->
    <section class="section">
      <div class="container post-body">
        <div class="post-content">
          <slot />
        </div>
        <aside class="post-sidebar">
          <div class="sidebar-block">
            <p class="sidebar-label">Published</p>
            <p class="sidebar-value">{formattedDate}</p>
          </div>
          <div class="sidebar-block">
            <p class="sidebar-label">Reading Time</p>
            <p class="sidebar-value">{readingTime} min</p>
          </div>
          {tags.length > 0 && (
            <div class="sidebar-block">
              <p class="sidebar-label">Tags</p>
              <Tags tags={tags} />
            </div>
          )}
        </aside>
      </div>
    </section>

  </article>
</Base>

<style>
  .back-row {
    padding-top: calc(var(--nav-height) + var(--space-8));
    padding-bottom: var(--space-4);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* HERO */
  .post-hero {
    padding: var(--space-8) 0 var(--space-16);
    border-bottom: 1px solid var(--border);
  }

  .post-hero h1 {
    margin: var(--space-6) 0 var(--space-4);
    max-width: 20ch;
  }

  .post-excerpt {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .post-meta-divider {
    color: var(--border);
  }

  /* BODY */
  .post-body {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-16);
    align-items: start;
  }

  .post-content {
    min-width: 0;
  }

  /* Prose styles for MDX content */
  .post-content :global(h2) {
    font-size: var(--text-2xl);
    margin: var(--space-12) 0 var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }

  .post-content :global(h3) {
    font-size: var(--text-xl);
    margin: var(--space-8) 0 var(--space-3);
    color: var(--text-primary);
  }

  .post-content :global(p) {
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    max-width: 68ch;
    line-height: 1.8;
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    opacity: 0.75;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    color: var(--text-secondary);
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
    max-width: 68ch;
  }

  .post-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.7;
  }

  .post-content :global(code) {
    background: var(--bg-elevated);
    color: var(--accent);
    padding: 2px var(--space-2);
    border-radius: 2px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    margin-bottom: var(--space-6);
  }

  .post-content :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .post-content :global(img) {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin: var(--space-8) 0;
  }

  .post-content :global(video) {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin: var(--space-8) 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-12) 0;
  }

  /* SIDEBAR */
  .post-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-8));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-6);
  }

  .sidebar-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sidebar-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    max-width: none;
  }

  .sidebar-value {
    font-size: var(--text-sm);
    color: var(--text-primary);
    max-width: none;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .post-body {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
    }
  }
</style>